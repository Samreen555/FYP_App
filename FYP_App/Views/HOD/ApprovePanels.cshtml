@model IEnumerable<FYP_App.Models.Panel>
@{
    ViewData["Title"] = "Approve Defense Panels";
}

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-secondary"><i class="fas fa-check-double me-2 text-primary"></i>Pending Panel Approvals</h4>
    </div>

    @if (!Model.Any())
    {
            <div class="alert alert-info shadow-sm border-0">
                <i class="fas fa-info-circle me-2"></i>No pending panels. All panels have been approved.
            </div>
    }
    else
    {
            <div class="row">
            @foreach (var panel in Model)
            {
                        <div class="col-md-6 mb-4">
                            <div class="card shadow-sm border-0 h-100 border-start border-4 border-warning">
                                <div class="card-header bg-white pt-3">
                                    <h5 class="fw-bold text-dark mb-0">@panel.Name</h5>
                                    <span class="badge bg-warning text-dark mt-1">Pending Approval</span>
                                </div>
                                <div class="card-body">
                                    <label class="small text-muted fw-bold text-uppercase mb-2">Composition</label>
                                    <ul class="list-group list-group-flush mb-3">
                                @foreach (var member in panel.Members)
                                {
                                                <li class="list-group-item px-0 py-1 d-flex justify-content-between align-items-center">
                                                    <span><i class="fas fa-user-tie text-secondary me-2"></i>@member.User.FullName</span>
                                        @if (member.Role == "Internal")
                                        {
                                            <span class="badge bg-info text-dark">Internal</span>
                                        }
                                        else if (member.Role == "External")
                                        {
                                            <span class="badge bg-danger">External</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">Member</span>
                                        }
                                                </li>
                                }
                                    </ul>

                                    <div class="d-flex gap-2">
                                        <form asp-action="ApprovePanel" method="post" class="w-50">
                                            <input type="hidden" name="id" value="@panel.Id" />
                                            <button type="submit" class="btn btn-success w-100 fw-bold">
                                                <i class="fas fa-check me-2"></i>Approve
                                            </button>
                                        </form>
                                        <form asp-action="RejectPanel" method="post" class="w-50" onsubmit="return confirm('Reject and Delete this panel?');">
                                            <input type="hidden" name="id" value="@panel.Id" />
                                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                                                <i class="fas fa-times me-2"></i>Reject
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
            }
            </div>
    }
</div>