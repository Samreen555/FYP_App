@{
    ViewData["Title"] = "HOD Dashboard";
}

<style>
    
    .bg-theme-teal { background-color: #76e4e6; color: #2c3e50; }
    .text-theme-teal { color: #2baab1; }
    .border-left-teal { border-left: 5px solid #76e4e6; }
</style>

<div class="container-fluid mt-4">
    <h4 class="text-secondary mb-4"><i class="fas fa-building me-2"></i>HOD Dashboard</h4>

    <div class="row mb-4">

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 border-left-teal">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Pending Panels</h6>
                        <h2 class="mb-0 fw-bold text-theme-teal">@ViewBag.PendingPanels</h2>
                    </div>
                    <div class="bg-light rounded-circle p-3 text-secondary">
                        <i class="fas fa-users-cog fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 border-left-teal" style="border-left-color: #4A69BD !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Total Projects</h6>
                        <h2 class="mb-0 fw-bold" style="color: #4A69BD;">@ViewBag.TotalProjects</h2>
                    </div>
                    <div class="bg-light rounded-circle p-3 text-secondary">
                        <i class="fas fa-project-diagram fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 border-left-teal" style="border-left-color: #20c997 !important;">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Completed Projects</h6>
                        <h2 class="mb-0 fw-bold text-success">@ViewBag.CompletedProjects</h2>
                    </div>
                    <div class="bg-light rounded-circle p-3 text-secondary">
                        <i class="fas fa-check-circle fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-theme-teal text-white">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-gavel me-2"></i>Approvals</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Review and approve defense panels created by the Coordinator.</p>
                    <a asp-action="ApprovePanels" class="btn btn-outline-dark w-100">Manage Panels</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-theme-teal text-white">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-poll me-2"></i>Reports</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">View final thesis submissions and consolidated grading sheets.</p>
                    <a asp-action="FinalResults" class="btn btn-outline-dark w-100">View Results</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-danger text-white">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle me-2"></i>System Alerts</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Monitor inactive students (missed 2+ weeks) and supervisors.</p>
                    <a asp-action="SystemAlerts" class="btn btn-outline-danger w-100">Check Inactivity</a>
                </div>
            </div>
        </div>

    </div>
</div>