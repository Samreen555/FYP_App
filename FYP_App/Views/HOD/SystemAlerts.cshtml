@model IEnumerable<FYP_App.Models.SystemAlertViewModel>
@{
    ViewData["Title"] = "System Alerts";
}

<style>
    .bg-theme-red { background-color: #dc3545; color: white; }
</style>

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-secondary"><i class="fas fa-exclamation-triangle me-2 text-danger"></i>Inactivity Reports</h4>
    </div>

    @if (!Model.Any())
    {
            <div class="alert alert-success shadow-sm border-0">
                <i class="fas fa-check-circle me-2"></i>System Healthy. No major inactivity detected.
            </div>
    }
    else
    {
            <div class="row mb-5">
            @foreach (var alert in Model)
            {
                        <div class="col-md-6 mb-4">
                            <div class="card shadow-sm border-0 h-100 border-start border-4 @(alert.Type == "Student" ? "border-danger" : "border-warning")">
                                <div class="card-header bg-white pt-3 d-flex justify-content-between">
                                    <h5 class="fw-bold text-dark mb-0">@alert.PersonName</h5>
                                    <span class="badge @(alert.Type == "Student" ? "bg-danger" : "bg-warning text-dark")">@alert.Type Alert</span>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted mb-1"><strong>Project:</strong> @alert.ProjectTitle</p>
                                    <p class="text-danger fw-bold"><i class="fas fa-clock me-2"></i>@alert.Issue</p>
                                    <hr />

                            @if (alert.Type == "Student")
                            {
                                            <div class="d-flex gap-2">
                                                <form asp-action="AllowStudent" method="post" class="w-50">
                                                    <input type="hidden" name="projectId" value="@alert.ProjectId" />
                                                    <button type="submit" class="btn btn-outline-warning w-100 text-dark fw-bold">
                                                        <i class="fas fa-exclamation-circle me-2"></i>Warn Student
                                                    </button>
                                                </form>

                                                <form asp-action="BlockStudent" method="post" class="w-50" onsubmit="return confirm('WARNING: Cancel student registration?');">
                                                    <input type="hidden" name="projectId" value="@alert.ProjectId" />
                                                    <button type="submit" class="btn btn-danger w-100 fw-bold">
                                                        <i class="fas fa-ban me-2"></i>Block Student
                                                    </button>
                                                </form>
                                            </div>
                            }
                            else
                            {
                                            <div class="alert alert-light small p-2 mb-2 text-center border">
                                                Supervisor is delaying the workflow.
                                            </div>
                                            <form asp-action="ReportSupervisor" method="post" class="w-100">
                                                <input type="hidden" name="projectId" value="@alert.ProjectId" />
                                                <button type="submit" class="btn btn-warning w-100 fw-bold text-dark">
                                                    <i class="fas fa-bullhorn me-2"></i>Report to Coordinator
                                                </button>
                                            </form>
                            }
                                </div>
                            </div>
                        </div>
            }
            </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3 mt-5">
        <h5 class="text-secondary"><i class="fas fa-user-slash me-2 text-muted"></i>Blocked Students</h5>
    </div>

    @{
        var blockedList = ViewBag.BlockedStudents as List<FYP_App.Models.Project>;
    }

    @if (blockedList != null && blockedList.Any())
    {
            <div class="card shadow-sm border-0">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Student Name</th>
                                <th>Reg No</th>
                                <th>Project Title</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var p in blockedList)
                        {
                                    <tr>
                                        <td class="ps-4 fw-bold">@p.Student.FullName</td>
                                        <td>@p.Student1RegNo</td>
                                        <td class="text-muted">@p.Title</td>
                                        <td>
                                            <form asp-action="UnblockStudent" method="post" onsubmit="return confirm('Reactivate this student account?');">
                                                <input type="hidden" name="projectId" value="@p.Id" />
                                                <button type="submit" class="btn btn-sm btn-success fw-bold">
                                                    <i class="fas fa-unlock me-2"></i>Unblock
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
    }
    else
    {
            <div class="alert alert-light border text-center text-muted">
                No students are currently blocked.
            </div>
    }
</div>