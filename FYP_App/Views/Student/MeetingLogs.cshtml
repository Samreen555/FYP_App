@model IEnumerable<FYP_App.Models.MeetingLog>
@{
    ViewData["Title"] = "My Meeting Logs";
}

<style>
    
    .bg-theme-blue { background-color: #4A69BD; color: white; }
    .btn-theme-blue { background-color: #4A69BD; color: white; border: none; }
    .btn-theme-blue:hover { background-color: #3c559c; color: white; }
</style>

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-secondary"><i class="fas fa-book me-2" style="color:#4A69BD"></i>Digital Log Book</h4>

        @if (ViewBag.CanAdd)
        {
                <button class="btn btn-theme-blue shadow-sm" data-bs-toggle="modal" data-bs-target="#createLogModal">
                    <i class="fas fa-plus-circle me-2"></i>Add New Log
                </button>
        }
        else
        {
                <span class="badge bg-secondary">Log Limit Reached</span>
        }
    </div>

    <div class="alert alert-light border shadow-sm mb-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <strong>Current Phase:</strong> <span class="badge bg-info text-dark">@ViewBag.CurrentPhase</span>
            </div>
            <div class="col-md-6 text-end">
                <small class="text-muted">Total Logs: @Model.Count() / 24</small>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Log #</th>
                        <th>Date</th>
                        <th style="width: 40%;">Details</th>
                        <th>Supervisor Remarks</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted">No logs recorded yet.</td></tr>
                    }

                    @foreach (var log in Model)
                    {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@log.MeetingNumber</td>
                                <td>@log.MeetingDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <p class="mb-1 text-dark small"><strong>Done:</strong> @log.StudentActivities</p>
                                    <p class="mb-0 text-muted small"><strong>Plan:</strong> @log.NextMeetingPlan</p>
                                </td>
                                <td><span class="text-muted small">@(log.SupervisorComments ?? "-")</span></td>
                                <td>
                                @if (log.Status == "Verified")
                                {
                                    <span class="badge bg-success">Verified</span>
                                }
                                else if (log.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                </td>
                                <td>
                                @if (log.Status == "Pending")
                                {
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editLog-@log.Id" title="Edit Log">
                                                    <i class="fas fa-edit"></i>
                                                </button>

                                                <form asp-action="DeleteLogEntry" method="post" onsubmit="return confirm('Delete Log #@log.MeetingNumber?');" style="display:inline;">
                                                    <input type="hidden" name="logId" value="@log.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-1" title="Delete Log">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>

                                            <div class="modal fade" id="editLog-@log.Id" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <form asp-action="EditLogEntry" method="post">
                                                            <div class="modal-header bg-theme-blue text-white">
                                                                <h5 class="modal-title">Edit Log #@log.MeetingNumber</h5>
                                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <input type="hidden" name="logId" value="@log.Id" />

                                                                <div class="mb-3">
                                                                    <label class="form-label fw-bold">Activities Performed</label>
                                                                    <textarea name="activities" class="form-control" rows="3" required>@log.StudentActivities</textarea>
                                                                </div>
                                                                <div class="mb-3">
                                                                    <label class="form-label fw-bold">Next Meeting Plan</label>
                                                                    <textarea name="plan" class="form-control" rows="2" required>@log.NextMeetingPlan</textarea>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                                <button type="submit" class="btn btn-theme-blue">Save Changes</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                }
                                else
                                {
                                            <span class="text-muted" title="Log is locked (Verified/Rejected)">
                                                <i class="fas fa-lock opacity-50"></i>
                                            </span>
                                }
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createLogModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateLogEntry" method="post">
                <div class="modal-header bg-theme-blue text-white">
                    <h5 class="modal-title">New Meeting Log</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Meeting Date</label>
                        <input type="date" name="MeetingDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Activities Performed</label>
                        <textarea name="StudentActivities" class="form-control" rows="3" placeholder="What did you work on?" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Next Meeting Plan</label>
                        <textarea name="NextMeetingPlan" class="form-control" rows="2" placeholder="Tasks for next week..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-theme-blue">Save Log Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>