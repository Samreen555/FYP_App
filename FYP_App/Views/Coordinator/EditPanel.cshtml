@model FYP_App.Models.Panel
@{
    ViewData["Title"] = "Edit Panel";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Edit Panel: @Model.Name</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="EditPanel" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Panel Name</label>
                    <input name="Name" class="form-control" value="@Model.Name" required />
                </div>

                <label class="form-label fw-bold mb-2">Manage Members</label>
                <div class="border rounded p-0" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th style="width: 50px;" class="text-center">Select</th>
                                <th>Name / Email</th>
                                <th class="text-end pe-4">Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var facultyList = ViewBag.FacultyList as IEnumerable<dynamic>;
                            }
                            @foreach (var person in facultyList)
                            {
                                    <tr>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" name="MemberIds" 
                                                   value="@person.Id" @(person.IsSelected ? "checked" : "")>
                                        </td>
                                        <td>
                                            <strong>@person.Name</strong><br/>
                                            <small class="text-muted">@person.Email</small>
                                        </td>
                                        <td class="text-end pe-4">
                                            <span class="badge @person.Badge">@person.Category</span>
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="ManagePanels" class="btn btn-secondary me-2">Cancel</a>
                    <button type="submit" class="btn btn-primary fw-bold">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>