@model IEnumerable<FYP_App.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<style>
    .bg-theme { background-color: #7B7D9C; color: white; }
    .text-theme { color: #7B7D9C; }

    
    .nav-tabs .nav-link { 
        color: #6c757d !important; 
        font-weight: 500; 
    }

    .nav-tabs .nav-link:hover {
        color: #7B7D9C !important; 
        background-color: #f8f9fa;
    }

    .nav-tabs .nav-link.active { 
        color: #7B7D9C !important; 
        border-top: 3px solid #7B7D9C; 
        font-weight: bold; 
        background-color: white;
    }
</style>

<div class="container-fluid mt-4">

    @if (TempData["Success"] != null)
    {
            <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
            <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="text-secondary"><i class="fas fa-users-cog me-2"></i>User Management</h4>
        <a asp-action="CreateUser" class="btn btn-outline-dark shadow-sm">
            <i class="fas fa-user-plus me-2"></i> Create New User
        </a>
    </div>

    <ul class="nav nav-tabs mb-3 shadow-sm bg-white rounded-top">
        @foreach (var role in ViewBag.Roles as List<string>)
        {
                <li class="nav-item">
                    <a class="nav-link @(ViewBag.CurrentRole == role ? "active" : "")" 
                       asp-action="ManageUsers" asp-route-role="@role">
                    @role
                    </a>
                </li>
        }
    </ul>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th>Email / Username</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                            <tr><td colspan="4" class="text-center py-5 text-muted">No users found in this role.</td></tr>
                    }

                    @foreach (var user in Model)
                    {
                            <tr>
                                <td class="ps-4 fw-bold">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3" 
                                             style="width: 40px; height: 40px; color: #7B7D9C;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                    @user.FullName
                                    </div>
                                </td>
                                <td class="text-secondary">@user.Email</td>
                                <td><span class="badge bg-secondary">@ViewBag.CurrentRole</span></td>

                                <td>
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary shadow-sm">
                                        <i class="fas fa-edit me-1"></i> Edit
                                    </a>
                                </td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>