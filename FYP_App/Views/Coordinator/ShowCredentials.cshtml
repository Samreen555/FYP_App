@{
    ViewData["Title"] = "Account Created";
    
    var name = TempData["NewName"];
    var email = TempData["NewEmail"];
    var pass = TempData["NewPassword"];
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header text-white text-center py-4" style="background-color: #7B7D9C;">
            <div class="mb-2"><i class="fas fa-user-check fa-3x"></i></div>
            <h4 class="mb-0">Group Approved & Account Created</h4>
        </div>
        <div class="card-body p-4 text-center">
            <p class="text-muted">
                Please copy the login credentials below and send them to <strong>@name</strong> (Student 1).
            </p>

            <div class="alert alert-light border p-4 mb-4">
                <div class="row mb-2">
                    <div class="col-4 text-end fw-bold text-secondary">Email:</div>
                    <div class="col-8 text-start user-select-all">@email</div>
                </div>
                <div class="row">
                    <div class="col-4 text-end fw-bold text-secondary">Password:</div>
                    <div class="col-8 text-start text-danger fw-bold user-select-all">@pass</div>
                </div>
            </div>

            <div class="d-grid gap-2">
                <a asp-action="ManageProjects" class="btn text-white fw-bold" style="background-color: #7B7D9C;">
                    <i class="fas fa-arrow-right me-2"></i> Continue to Project List
                </a>
            </div>
        </div>
        <div class="card-footer text-center bg-light text-muted small">
            Note: This password will not be shown again for security reasons.
        </div>
    </div>
</div>