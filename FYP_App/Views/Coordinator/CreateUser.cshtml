@{
    ViewData["Title"] = "Create User";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>Create New User</h5>
        </div>
        <div class="card-body p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="CreateUser" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input name="FullName" class="form-control" required placeholder="e.g. Dr. Sarah Smith" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Email Address</label>
                    <input name="Email" type="email" class="form-control" required placeholder="name@example.com" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Role</label>
                    <select id="roleSelect" name="Role" class="form-select" required onchange="togglePanelOptions()">
                        <option value="">-- Select Role --</option>
                        <option value="Student">Student</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="Panel">Defense Panel</option>
                        <option value="HOD">Head of Department</option>
                        <option value="Coordinator">Coordinator</option>
                    </select>
                </div>

                <div id="panelTypeDiv" class="mb-3 bg-light p-3 rounded border" style="display:none;">
                    <label class="form-label fw-bold text-danger">Panelist Type</label>
                    <select name="PanelistType" class="form-select">
                        <option value="Member">General Member (Initial/Midterm)</option>
                        <option value="Internal">Internal Examiner (Final Defense)</option>
                        <option value="External">External Examiner (Final Defense)</option>
                    </select>
                    <div class="form-text small">Specify if this user serves as an Internal or External examiner for Final Defenses.</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Password</label>
                    <div class="input-group">
                        <input id="passwordInput" name="Password" type="password" class="form-control" required />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword()">
                            <i id="toggleIcon" class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary fw-bold">Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Logic to show/hide Panel sub-options
    function togglePanelOptions() {
        var role = document.getElementById("roleSelect").value;
        var panelDiv = document.getElementById("panelTypeDiv");

        if (role === "Panel") {
            panelDiv.style.display = "block";
        } else {
            panelDiv.style.display = "none";
        }
    }

    // Logic to show/hide Password
    function togglePassword() {
        var input = document.getElementById("passwordInput");
        var icon = document.getElementById("toggleIcon");

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
</script>