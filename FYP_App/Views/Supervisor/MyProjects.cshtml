@model IEnumerable<FYP_App.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<style>
    .bg-theme-orange { background-color: #E08E45; color: white; }
</style>

<div class="container-fluid mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-theme-orange d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-users me-2"></i>My Assigned Groups</h5>
            <span class="badge bg-light text-dark">@Model.Count() Groups</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4" style="width: 30%;">Project Title</th>
                        <th style="width: 25%;">Student 1</th>
                        <th style="width: 25%;">Student 2</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted">No projects assigned yet.</td></tr>
                    }

                    @foreach (var item in Model)
                    {
                        
                        string s2Name = "N/A";
                        string s2Reg = "";
                        string desc = item.Description ?? "";

                        if (desc.Contains("Partner:"))
                        {
                            try
                            {
                                string rawS2 = desc.Split("Partner:")[1].Trim();
                                int openParen = rawS2.LastIndexOf('(');
                                if (openParen > 0)
                                {
                                    s2Name = rawS2.Substring(0, openParen).Trim();
                                    s2Reg = rawS2.Substring(openParen).Replace("(", "").Replace(")", "").Trim();
                                }
                                else
                                {
                                    s2Name = rawS2;
                                }
                            }
                            catch { }
                        }

                            <tr>
                                <td class="ps-4 fw-bold">@item.Title</td>

                                <td>
                                    <span class="fw-bold text-dark">@(item.Student?.FullName ?? "Unknown")</span><br/>
                                    <span class="small text-muted">@item.Student1RegNo</span>
                                </td>

                                <td>
                                    <span class="fw-bold text-dark">@s2Name</span><br/>
                                    <span class="small text-muted">@s2Reg</span>
                                </td>

                                <td><span class="badge bg-success">Active</span></td>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>