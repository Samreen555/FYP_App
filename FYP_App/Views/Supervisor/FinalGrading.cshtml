@{
    ViewData["Title"] = "Final Grading";
}

<style>
    .bg-theme-orange { background-color: #E08E45; color: white; }
    .btn-theme-orange { background-color: #E08E45; color: white; border: none; }
    .disabled-overlay { opacity: 0.5; pointer-events: none; }
</style>

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <h4 class="text-secondary mb-4"><i class="fas fa-star me-2" style="color:#E08E45"></i>Final Grading (Supervisor)</h4>

    <div class="card shadow border-0">
        <div class="card-header bg-theme-orange">
            <h5 class="mb-0">Evaluations</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Project Title</th>
                        <th>Student</th>
                        <th>Final Defense Date</th>
                        <th>Supervisor Marks (30)</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @{ 
                        var defenses = ViewBag.Defenses as IEnumerable<FYP_App.Models.DefenseSchedule>;
                        var today = DateTime.Today;
                    }

                    @foreach (dynamic item in ViewBag.Data)
                    {
                        var proj = item.Project as FYP_App.Models.Project;
                        var grade = item.Grade as FYP_App.Models.ProjectGrade;

                        
                        var def = defenses?.FirstOrDefault(d => d.ProjectId == proj.Id);
                        bool isEditable = (def != null && def.Date.Date == today);

                            <tr>
                                <td class="ps-4 fw-bold">@proj.Title</td>
                                <td>@(proj.Student?.FullName ?? "Unknown")</td>

                                <td>
                                @if (def != null)
                                { 
                                            <span class="@(isEditable ? "text-success fw-bold" : "text-muted")">
                                        @def.Date.ToString("dd MMM yyyy")
                                            </span>
                                }
                                else
                                {
                                    <span class="text-danger small">Not Scheduled</span>
                                }
                                </td>

                                <form asp-action="SaveFinalGrade" method="post">
                                    <input type="hidden" name="projectId" value="@proj.Id" />

                                    <td>
                                        <div class="input-group" style="width: 120px;">
                                            <input type="number" step="0.5" min="0" max="30" name="marks" 
                                                   class="form-control text-center fw-bold" 
                                                   value="@(grade?.SupervisorMarks)" 
                                        @(isEditable ? "" : "disabled") placeholder="-" />
                                        </div>
                                    </td>
                                    <td>
                                    @if (isEditable)
                                    {
                                                <button type="submit" class="btn btn-sm btn-theme-orange">Save</button>
                                    }
                                    else
                                    {
                                                <span class="badge bg-secondary">Locked</span>
                                                <i class="fas fa-info-circle text-muted ms-1" 
                                                   title="Grading opens only on the day of Final Defense"></i>
                                    }
                                    </td>
                                </form>
                            </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>