@{
    ViewData["Title"] = "Registration Successful";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .success-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        text-align: center;
    }

    .success-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); 
        color: white;
        padding: 3rem;
    }

    .icon-circle {
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .btn-home {
        background-color: #2c3e50;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 50px;
        transition: all 0.3s;
    }

    .btn-home:hover {
        background-color: #34495e;
        transform: translateY(-2px);
        color: white;
    }
</style>

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="card success-card">
        <div class="success-header">
            <div class="icon-circle">
                <i class="fas fa-check fa-3x"></i>
            </div>
            <h2 class="fw-bold">Registration Received!</h2>
            <p class="mb-0 opacity-75">Your group details have been submitted successfully.</p>
        </div>
        <div class="card-body p-5">
            <h5 class="text-secondary mb-3">What happens next?</h5>
            <p class="text-muted">
                The FYP Coordinator will review your registration details. Once approved, the login credentials for your group account will be sent to the <strong>Student 1 (Primary) Email Address</strong> provided.
            </p>

            <hr class="my-4 w-50 mx-auto opacity-25">

            <a asp-controller="Account" asp-action="Login" class="btn btn-home fw-bold shadow-sm">
                <i class="fas fa-home me-2"></i> Return to Home
            </a>
        </div>
    </div>
</div>